                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>UNALIGNED</name>
              <description>Unaligned access flag. Sticky flag indicating whether an unaligned access error has occurred.</description>
              <bitRange>[8:8]</bitRange>
              <enumeratedValues>
                <enumeratedValue>
                  <value>0</value>
                  <description>Error has not occurred</description>
                </enumeratedValue>
