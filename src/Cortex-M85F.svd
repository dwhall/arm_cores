            <field>
              <name>Writeback</name>
              <description>Indicates the support for writeback addressing modes</description>
              <bitRange>[11:8]</bitRange>
              <enumeratedValues>
                <enumeratedValue>
                  <value>1</value>
                  <description>All writeback addressing modes supported</description>
                </enumeratedValue>
              </enumeratedValues>
