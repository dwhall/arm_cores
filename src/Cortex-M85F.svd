              <name>DIVBYZERO</name>
              <description>Divide by zero flag. Sticky flag indicating whether an integer division by zero error has occurred.</description>
              <bitRange>[9:9]</bitRange>
              <enumeratedValues>
                <enumeratedValue>
                  <value>0</value>
                  <description>Error has not occurred</description>
                </enumeratedValue>
