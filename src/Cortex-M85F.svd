                <enumeratedValue>
                  <value>1</value>
                  <description>BusFault occurred during FP lazy state preservation</description>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>STKERR</name>
              <description>BusFault on stacking for exception entry</description>
              <bitRange>[4:4]</bitRange>
              <enumeratedValues>
                <enumeratedValue>
                  <value>0</value>
