                  <description>ERRADDR0 is not valid</description>
                </enumeratedValue>
                <enumeratedValue>
                  <value>1</value>
                  <description>ERRADDR0 is valid</description>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>V</name>
              <description>Status valid</description>
              <bitRange>[30:30]</bitRange>
              <enumeratedValues>
                <enumeratedValue>
