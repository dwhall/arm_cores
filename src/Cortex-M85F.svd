                  <value>1</value>
                  <description>Instruction bus error has occurred</description>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>UFSR</name>
          <description>Usage Fault Status Register indicates the cause of a UsageFault</description>
