                  <description>No BusFault due to RPOISON or TEBRn.POISON has occurred</description>
                </enumeratedValue>
                <enumeratedValue>
                  <value>1</value>
                  <description>At least one BusFault due to RPOISON or TEBRn.POISON has occurred</description>
